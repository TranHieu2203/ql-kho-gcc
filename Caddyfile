# Caddyfile cho ql-kho-gcc
# Caddy 2 tự cấp & gia hạn Let's Encrypt cho {$DOMAIN}.
# Yêu cầu: domain đã trỏ A/AAAA record về IP server + cổng 80/443 mở.

{
    email {$ACME_EMAIL}
    # Production: bật log JSON cho parsing
    log {
        output stdout
        format console
        level INFO
    }
}

{$DOMAIN} {
    encode zstd gzip

    # Reverse proxy → Next.js app container
    reverse_proxy app:3000 {
        # Forward client IP cho rate limit + audit log
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
        header_up Host {host}

        # Health check upstream
        health_uri /api/health
        health_interval 30s
        health_timeout 5s
        health_status 200
    }

    # Defense-in-depth: vài header bổ sung (Next.js cũng đặt nhưng để chắc)
    header {
        # Caddy tự thêm Strict-Transport-Security cho HTTPS rồi nhưng explicit cho an toàn
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Frame-Options "DENY"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"
        # Loại bỏ Server header tiết lộ tech stack
        -Server
    }

    # Log access (request only, không log body)
    log {
        output stdout
        format console
    }

    # Compress + cache cho static assets
    @static {
        path /_next/static/* /fonts/* /icons/* /favicon.ico
    }
    header @static Cache-Control "public, max-age=31536000, immutable"

    # Block các path nhạy cảm vô tình expose
    @blocked {
        path /.env /.git/* /Dockerfile /docker-compose.yml /prisma/* /node_modules/*
    }
    respond @blocked 404

    # File upload size (cho import Excel ~8MB)
    request_body {
        max_size 12MB
    }
}

# Redirect www → apex (tùy chọn — uncomment nếu bạn có www subdomain)
# www.{$DOMAIN} {
#     redir https://{$DOMAIN}{uri} permanent
# }
