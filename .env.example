# ===== ql-kho-gcc — production env =====
# Copy file này thành .env trên server trước khi `docker compose up`
#
# Phiên bản hiện tại KHÔNG có Caddy — bạn dùng reverse proxy có sẵn
# (Nginx Proxy Manager / nginx / Traefik / Cloudflare Tunnel).
# Domain + TLS được quản lý ở reverse proxy, không phải biến env của app.

# --- Admin bootstrap (CHỈ cần lần khởi tạo đầu) ---
# Sau khi admin đã được tạo, XÓA 3 dòng dưới hoặc đổi
# ADMIN_INITIAL_PASSWORD thành rỗng + restart.
ADMIN_INITIAL_PASSWORD=ChangeMe!Strong123
ADMIN_USERNAME=admin
ADMIN_FULL_NAME=Quản trị viên

# --- Backup Google Sheets cron token (≥16 ký tự ngẫu nhiên) ---
# Sinh bằng: openssl rand -hex 24
# Để rỗng nếu chưa dùng feature backup → endpoint /api/cron/backup trả 503
CRON_SECRET=

# --- Reverse proxy Docker network (cho NPM/Traefik trong Docker) ---
# Mục đích: cho phép NPM container gọi tới ql-kho-app qua Docker DNS
#   (URL nội bộ: http://ql-kho-app:3000)
#
# Lấy tên network bằng:
#   docker inspect <npm-container> -f '{{range $k,$v := .NetworkSettings.Networks}}{{$k}} {{end}}'
#
# Nếu KHÔNG dùng NPM trong Docker (vd: NPM bare metal, Cloudflare Tunnel,
# Traefik standalone) → để mặc định `bridge` (vô hại, không cần đổi).
NPM_NETWORK=bridge
