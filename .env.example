# ===== ql-kho-gcc — production env =====
# Copy file này thành .env trên server trước khi `docker compose up`

# --- Domain & TLS ---
# Tên miền chính (KHÔNG kèm https:// hoặc trailing slash)
DOMAIN=ql-kho.example.com

# Email cho Let's Encrypt cấp/gia hạn cert + cảnh báo expire
ACME_EMAIL=admin@example.com

# --- Admin bootstrap (CHỈ cần lần khởi tạo đầu) ---
# Sau khi admin đã được tạo, XÓA 3 dòng dưới hoặc đổi
# ADMIN_INITIAL_PASSWORD thành rỗng + restart.
ADMIN_INITIAL_PASSWORD=ChangeMe!Strong123
ADMIN_USERNAME=admin
ADMIN_FULL_NAME=Quản trị viên

# --- Backup Google Sheets cron token (≥16 ký tự ngẫu nhiên) ---
# Sinh bằng: openssl rand -hex 24
# Để rỗng nếu chưa dùng feature backup → endpoint /api/cron/backup trả 503
CRON_SECRET=
