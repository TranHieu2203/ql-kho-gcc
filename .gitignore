# ===== ql-kho-gcc — root .gitignore =====

# --- Node / Next.js ---
node_modules/
.next/
out/
build/
dist/
*.tsbuildinfo
next-env.d.ts

# --- Env / secrets ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
*.key
serviceAccount*.json
service-account*.json

# --- Database (KHÔNG commit DB local / production data) ---
**/prisma/dev.db
**/prisma/dev.db-journal
**/prisma/data/*.db
**/prisma/data/*.db-journal
**/data/*.db
**/data/*.db-journal
**/data/backups/

# --- Logs ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- OS / Editor ---
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# --- Misc ---
coverage/
.nyc_output/
.cache/
.parcel-cache/

# --- Docker volumes ---
caddy_data/
caddy_config/
